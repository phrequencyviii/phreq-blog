---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';

type Props = CollectionEntry<'photos'>['data'];

const { title, description, pubDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={title ?? 'Photo'}
			description={description ?? SITE_DESCRIPTION}
			image={heroImage}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.photo {
				width: 100%;
				max-width: 900px;
				margin: 0 auto;
				padding: 1em;
			}
			.photo img {
				width: 100%;
				height: auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.meta {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 1em auto 0;
				padding: 0 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 0.5em;
			}
			.date {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.caption {
				margin-top: 0.75em;
				font-style: italic;
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="photo">
					<Image src={heroImage} alt={description ?? title ?? ''} width={1200} height={900} />
				</div>
				<div class="meta">
					{title && <h1 class="title">{title}</h1>}
					<div class="date"><FormattedDate date={pubDate} /></div>
					{description && <p class="caption">{description}</p>}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
