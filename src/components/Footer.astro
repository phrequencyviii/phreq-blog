---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} phreq</span>
	<span class="sep">·</span>
	<a href="/rss.xml">RSS</a>
</footer>
<style>
	footer {
		padding: 2em 1.5em;
		border-top: 1px solid #222222;
		color: rgb(var(--gray));
		font-family: var(--font-mono);
		font-size: 0.75em;
		letter-spacing: 0.04em;
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.sep {
		color: #333333;
	}
	a {
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.15s;
	}
	a:hover {
		color: var(--accent);
	}
</style>
