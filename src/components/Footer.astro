---
const today = new Date();
---

<footer>
	<div class="footer-main">
		<span>&copy; {today.getFullYear()} <a href="https://phreq.blog">phreq.blog</a></span>
		<span class="sep">·</span>
		<a href="/rss.xml">RSS</a>
	</div>
	<div class="footer-license">
		<a
			href="https://creativecommons.org/licenses/by-nc-sa/4.0/"
			target="_blank"
			rel="license noopener"
		>CC BY-NC-SA 4.0</a>
	</div>
</footer>
<style>
	footer {
		padding: 1.75em 1.5em;
		border-top: 1px solid var(--border);
		color: rgb(var(--gray));
		font-family: var(--font-mono);
		font-size: 0.72em;
		letter-spacing: 0.04em;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4em;
		text-align: center;
	}
	.footer-main {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.sep {
		color: rgb(var(--gray));
	}
	.footer-license {
		font-size: 0.88em;
		letter-spacing: 0.06em;
		color: rgb(var(--gray));
		opacity: 0.7;
	}
	a {
		color: rgb(var(--gray));
		text-decoration: none;
		transition: color 0.2s ease;
	}
	a:hover {
		color: var(--accent);
	}
</style>
